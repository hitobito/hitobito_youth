%p= t("events/courses.popover_bsv_export.export_info")

= standard_form(:bsv_export,
                url: :list_courses_bsv_export,
                method: :get,
                stacked: true,
                data: { turbo: false },
                builder: PlainObjectFormBuilder) do |f|

  = hidden_field_tag("filters[state][states][]", "closed")
  = hidden_field_tag(:advanced, true) if defined?(advanced) && advanced

  = f.labeled(t("events/courses.popover_bsv_export.event_kinds"), help: "f00") do
    = select_tag("filters[bsv_kind][ids]", options_from_collection_for_select(Event::Kind.includes(:translations).without_deleted, :id, :label), multiple: true, class: "form-select", data: { chosen_no_results: t("global.chosen_no_results"), placeholder: " ", controller: "tom-select" } )

  = f.labeled(t("events/courses.popover_bsv_export.date_from")) do
    .input-group.w-50
      .input-prepend
        %span.input-group-text= icon(:"calendar-alt")
      = text_field_tag("filters[bsv_date_range][since]", f(Date.today.beginning_of_year), class: "date form-control form-control-sm")

  = f.labeled(t("events/courses.popover_bsv_export.date_to")) do
    .input-group.w-50
      .input-prepend
        %span.input-group-text= icon(:"calendar-alt")
      = text_field_tag("filters[bsv_date_range][until]", f(Date.today.end_of_year), class: "date form-control form-control-sm")

  = form_buttons(f, submit_label: t("events/courses.bsv_export_button"), cancel_url: :list_courses)
